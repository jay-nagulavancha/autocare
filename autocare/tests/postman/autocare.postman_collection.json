{
  "info": {
    "name": "Autocare End-to-End Tests",
    "description": "28 tests covering all APIs. Re-runnable with unique RUN_ID per run. Run in order.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('RUN_ID') || pm.environment.get('RUN_ID') === '') {",
          "  pm.environment.set('RUN_ID', Date.now().toString().slice(-8));",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "1. Auth - Register Admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200',()=>pm.response.to.have.status(200));",
              "pm.test('Success',()=>pm.expect(pm.response.json().message).to.include('successfully'));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"username\":\"admin_{{RUN_ID}}\",\"email\":\"admin_{{RUN_ID}}@test.com\",\"password\":\"Admin@123\",\"role\":[\"admin\"]}"
        },
        "url": {
          "raw": "{{AUTH_URL}}/api/auth/signup",
          "host": [
            "{{AUTH_URL}}"
          ],
          "path": [
            "api",
            "auth",
            "signup"
          ]
        }
      }
    },
    {
