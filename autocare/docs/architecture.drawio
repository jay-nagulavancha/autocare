      <mxGeometry x="190" y="60" width="50" height="60" as="geometry" />
    </mxCell>

    <mxCell id="ui-box" value="vehicle-maintenance-ui&#xa;React + TypeScript + Vite&#xa;Served by Nginx :3000&#xa;&#xa;Pages:&#xa;• Login / Register&#xa;• Dashboard&#xa;• Work Orders&#xa;• Work Order Detail&#xa;• Scheduling&#xa;&#xa;Axios interceptor attaches&#xa;Authorization: Bearer &lt;JWT&gt;&#xa;on every API request" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=10;" vertex="1" parent="browser-group">
      <mxGeometry x="10" y="160" width="240" height="310" as="geometry" />
    </mxCell>

    <!-- ── USER AUTH SERVICE ──────────────────────────────────────── -->
    <mxCell id="auth-group" value="user-auth-service  :8080" style="swimlane;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="360" y="80" width="340" height="500" as="geometry" />
    </mxCell>

    <mxCell id="auth-controller" value="AuthController&#xa;&#xa;POST /api/auth/signup&#xa;POST /api/auth/signin" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=10;" vertex="1" parent="auth-group">
      <mxGeometry x="20" y="50" width="300" height="80" as="geometry" />
    </mxCell>

    <mxCell id="auth-security" value="Spring Security&#xa;&#xa;WebSecurityConfig&#xa;AuthTokenFilter (JWT validation)&#xa;AuthEntryPointJwt" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=10;" vertex="1" parent="auth-group">
      <mxGeometry x="20" y="150" width="300" height="90" as="geometry" />
    </mxCell>

    <mxCell id="jwt-utils-auth" value="JwtUtils&#xa;&#xa;generateJwtToken()&#xa;validateJwtToken()&#xa;getUserNameFromJwtToken()&#xa;HS256 + JWT_SECRET" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=10;" vertex="1" parent="auth-group">
      <mxGeometry x="20" y="260" width="300" height="100" as="geometry" />
    </mxCell>

    <mxCell id="auth-repo" value="UserRepository&#xa;RoleRepository&#xa;(Spring Data JPA)" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=10;" vertex="1" parent="auth-group">
      <mxGeometry x="20" y="380" width="300" height="60" as="geometry" />
    </mxCell>

    <mxCell id="auth-response" value="JwtResponse: { token, type, id, username, email, roles }" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=10;fontSize=10;" vertex="1" parent="auth-group">
      <mxGeometry x="20" y="455" width="300" height="30" as="geometry" />
    </mxCell>

    <!-- ── VEHICLE MAINTENANCE SERVICE ───────────────────────────── -->
    <mxCell id="maint-group" value="vehicle-maintenance-service  :8081" style="swimlane;startSize=30;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="760" y="80" width="380" height="500" as="geometry" />
    </mxCell>

    <mxCell id="maint-controllers" value="REST Controllers&#xa;&#xa;GET/POST/PUT/DELETE /api/v1/vehicles&#xa;GET/POST/PATCH      /api/v1/work-orders&#xa;POST/DELETE         /api/v1/work-orders/{id}/parts&#xa;POST/DELETE         /api/v1/work-orders/{id}/labor&#xa;GET/POST/DELETE     /api/v1/schedules&#xa;GET/POST/PUT/DELETE /api/v1/technicians&#xa;GET/POST/PUT/DELETE /api/v1/bays" style="rounded=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=10;fontSize=10;" vertex="1" parent="maint-group">
      <mxGeometry x="20" y="50" width="340" height="140" as="geometry" />
    </mxCell>

    <mxCell id="maint-security" value="Spring Security (JWT Resource Server)&#xa;&#xa;AuthTokenFilter — validates JWT locally&#xa;using shared JWT_SECRET (no auth service call)&#xa;Extracts username + roles from claims" style="rounded=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=10;fontSize=10;" vertex="1" parent="maint-group">
      <mxGeometry x="20" y="205" width="340" height="90" as="geometry" />
    </mxCell>

    <mxCell id="work-order-sm" value="Work Order State Machine&#xa;&#xa;OPEN → IN_PROGRESS → PENDING_PARTS&#xa;     → IN_PROGRESS → COMPLETED → INVOICED&#xa;&#xa;Invalid transition → HTTP 422" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=10;fontSize=10;" vertex="1" parent="maint-group">
      <mxGeometry x="20" y="310" width="340" height="90" as="geometry" />
    </mxCell>

    <mxCell id="maint-repo" value="VehicleRepository  WorkOrderRepository&#xa;TechnicianRepository  BayRepository&#xa;PartLineRepository  LaborLineRepository&#xa;ServiceScheduleRepository  (Spring Data JPA)" style="rounded=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=10;fontSize=10;" vertex="1" parent="maint-group">
      <mxGeometry x="20" y="415" width="340" height="65" as="geometry" />
    </mxCell>

    <!-- ── DATABASES ───────────────────────────────────────────────── -->
    <mxCell id="auth-db" value="auth_db (MySQL)&#xa;&#xa;roles&#xa;users&#xa;user_roles" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.rds;fillColor=#FF9900;strokeColor=#E07B00;align=center;" vertex="1" parent="1">
      <mxGeometry x="360" y="640" width="340" height="160" as="geometry" />
    </mxCell>

    <mxCell id="maint-db" value="maintenance_db (MySQL)&#xa;&#xa;vehicles  technicians  bays&#xa;work_orders  work_order_status_history&#xa;part_lines  labor_lines  service_schedules" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.rds;fillColor=#FF9900;strokeColor=#E07B00;align=center;" vertex="1" parent="1">
      <mxGeometry x="760" y="640" width="380" height="160" as="geometry" />
    </mxCell>

    <!-- ── JWT FLOW ANNOTATION ────────────────────────────────────── -->
    <mxCell id="jwt-flow" value="JWT Flow&#xa;&#xa;1. User logs in → Auth Service validates → returns signed JWT&#xa;2. UI stores JWT in browser storage&#xa;3. UI attaches Authorization: Bearer &lt;JWT&gt; on every request&#xa;4. Maintenance Service validates JWT locally (shared JWT_SECRET)&#xa;5. No inter-service calls at runtime — fully stateless" style="rounded=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;spacingLeft=10;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="1200" y="80" width="420" height="160" as="geometry" />
    </mxCell>

    <!-- ── ROLE ACCESS ANNOTATION ─────────────────────────────────── -->
    <mxCell id="roles-box" value="Role-Based Access&#xa;&#xa;ROLE_ADMIN      — full access&#xa;ROLE_TECHNICIAN — assigned work orders + vehicles&#xa;ROLE_CUSTOMER   — own vehicles + work orders (read-only)&#xa;&#xa;CUSTOMER sees only their own vehicles&#xa;TECHNICIAN can only write to assigned work orders" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=10;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="1200" y="270" width="420" height="160" as="geometry" />
    </mxCell>

    <!-- ── API DOCS ────────────────────────────────────────────────── -->
    <mxCell id="swagger" value="OpenAPI / Swagger&#xa;&#xa;GET /v3/api-docs&#xa;GET /swagger-ui.html&#xa;(maintenance service only)" style="rounded=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=10;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="1200" y="460" width="420" height="100" as="geometry" />
    </mxCell>

    <!-- ── HTTP STATUS CODES ───────────────────────────────────────── -->
    <mxCell id="http-codes" value="HTTP Status Codes&#xa;&#xa;200 OK  |  201 Created  |  204 No Content&#xa;400 Validation error  |  401 Unauthenticated&#xa;403 Forbidden  |  404 Not found&#xa;409 Conflict (duplicate VIN, bay conflict)&#xa;422 Invalid state transition / closed WO modification" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=10;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="1200" y="590" width="420" height="140" as="geometry" />
    </mxCell>

    <!-- ── CONNECTIONS ─────────────────────────────────────────────── -->

    <!-- Users → UI -->
    <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="user-admin" target="ui-box" parent="browser-group">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="user-tech" target="ui-box" parent="browser-group">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="user-cust" target="ui-box" parent="browser-group">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- UI → Auth Service -->
    <mxCell id="e4" value="POST /api/auth/signin&#xa;POST /api/auth/signup" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="ui-box" target="auth-controller" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- UI → Maintenance Service -->
    <mxCell id="e5" value="GET/POST/PUT/DELETE /api/v1/**&#xa;Authorization: Bearer &lt;JWT&gt;" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="ui-box" target="maint-controllers" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Auth → auth_db -->
    <mxCell id="e6" value="JPA" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="auth-repo" target="auth-db" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Maintenance → maint_db -->
    <mxCell id="e7" value="JPA" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="maint-repo" target="maint-db" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- JWT shared secret annotation -->
    <mxCell id="e8" value="shared JWT_SECRET&#xa;(no inter-service call)" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#9673a6;" edge="1" source="jwt-utils-auth" target="maint-security" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

  </root>
