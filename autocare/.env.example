# ─────────────────────────────────────────────────────────────────────────────
# Autocare — environment variables
# Copy this file to .env and fill in the values before running docker compose.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# Shared HS256 signing key — must be the same value in both backend services.
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=changeme_use_a_strong_base64_encoded_secret_here

# JWT token TTL in milliseconds (default: 24 hours)
JWT_EXPIRATION_MS=86400000

# MySQL root password — used by all services
DB_PASSWORD=changeme_strong_db_password
